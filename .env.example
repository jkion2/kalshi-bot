# ─────────────────────────────────────────────────────────────────────────────
# .env — Copy this file to .env and fill in your real values.
# NEVER commit .env to git. It's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Kalshi API credentials
# Get these from: https://kalshi.com/account/api  (or demo.kalshi.co for demo)
KALSHI_API_KEY=your_kalshi_private_key_here
KALSHI_API_KEY_ID=your_kalshi_key_id_here

# Set to "true" to use Kalshi's demo environment (fake money)
# Set to "false" ONLY when you are ready to trade real money
KALSHI_DEMO=true

# Anthropic API key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Starting bankroll in USD
# For paper/demo mode this is just for position sizing math
STARTING_BANKROLL=300
